# EduSkillKit 配置文件
# 复制此文件为 .env 并填入你的 API Key
# 也可以在 系统设置 页面直接输入 API Key（两种方式均可）

# DeepSeek API Key（获取地址：https://platform.deepseek.com）
DEEPSEEK_API_KEY=

# 通义千问 API Key（获取地址：https://dashscope.console.aliyun.com）
DASHSCOPE_API_KEY=

# 智谱清言 API Key（获取地址：https://open.bigmodel.cn）
ZHIPU_API_KEY=

# 月之暗面 API Key（获取地址：https://platform.moonshot.cn）
MOONSHOT_API_KEY=

# 腾讯混元 API Key（获取地址：https://console.cloud.tencent.com/hunyuan）
HUNYUAN_API_KEY=

# 零一万物 API Key（获取地址：https://platform.lingyiwanwu.com）
YI_API_KEY=

# 百川智能 API Key（获取地址：https://platform.baichuan-ai.com）
BAICHUAN_API_KEY=

# 讯飞星火 API Key（获取地址：https://xinghuo.xfyun.cn/sparkapi）
SPARK_API_KEY=

# MiMo API Key（获取地址：https://mimo.ai）
MIMO_API_KEY=
